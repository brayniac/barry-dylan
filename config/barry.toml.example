[server]
listen = "0.0.0.0:8181"
public_url = "https://barry.example.com"

# Three GitHub Apps, one per reviewer identity. They appear as distinct
# users in the PR UI (Barry, Other Barry, Other Other Barry). Only Barry
# receives webhooks; OB and OOB are write-only identities that mint
# installation tokens to post reviews and check-runs.
[github.barry]
app_id = 111111
private_key_path = "/etc/barry/barry-app.pem"
webhook_secret_env = "BARRY_WEBHOOK_SECRET"

[github.other_barry]
app_id = 222222
private_key_path = "/etc/barry/other-barry-app.pem"

[github.other_other_barry]
app_id = 333333
private_key_path = "/etc/barry/other-other-barry-app.pem"

[storage]
sqlite_path = "/var/lib/barry/barry.db"

[dispatcher]
debounce_secs = 30
worker_count = 4
job_timeout_secs = 1800
checker_timeout_secs = 600

# Per-identity LLM endpoints. Mix providers freely — Barry can be
# Anthropic, Other Barry a local llama.cpp, Other Other Barry OpenAI,
# and the judge a small fast model.
[llm.barry]
provider = "anthropic"
endpoint = "https://api.anthropic.com"
api_key_env = "ANTHROPIC_API_KEY"
model = "claude-sonnet-4-6"
max_tokens = 8192
request_timeout_secs = 300

[llm.other_barry]
provider = "openai"
endpoint = "http://localhost:8080/v1"
model = "qwen2.5-coder-32b"
max_tokens = 8192
request_timeout_secs = 300

[llm.other_other_barry]
provider = "openai"
endpoint = "https://api.openai.com/v1"
api_key_env = "OPENAI_API_KEY"
model = "gpt-4o"
max_tokens = 8192
request_timeout_secs = 300

# The judge reconciles Barry and Other Barry. Use a small, fast model.
[llm.judge]
provider = "anthropic"
endpoint = "https://api.anthropic.com"
api_key_env = "ANTHROPIC_API_KEY"
model = "claude-haiku-4-5-20251001"
max_tokens = 512
request_timeout_secs = 60

# /barry confer — who may summon another Barry on a PR, and how often.
# Roles match GitHub repo permissions ("read", "write", "maintain", "admin")
# plus the special "author" role (matches the PR author regardless of perms).
[confer]
allowed = ["author", "write", "maintain", "admin"]
max_per_pr = 2
